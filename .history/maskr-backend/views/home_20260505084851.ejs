<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Musicore</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="css/general.css" />
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <header class="py-2 mb-3 border-bottom bg-white">
    <div
      class="container d-flex align-items-center justify-content-between"
    >
      <div class="logo">
       <a href="home.html"> <img src="assets/logo.png" alt="logo" width="50" height="50" /></a>
      </div>
      <div class="dropdown">
        <button
          class="btn dropdown-toggle"
          type="button"
          data-bs-toggle="dropdown"
          style="
            background-color: white;
            border: 2px solid purple;
            color: black;" >
          Kies je mood
        </button>
        <ul class="dropdown-menu">
          <li><a class="dropdown-item" href="#"> Blij</a></li>
          <li><a class="dropdown-item" href="#"> Moe</a></li>
          <li><a class="dropdown-item" href="#"> Gemotiveerd</a></li>
          <li><a class="dropdown-item" href="#"> Relaxed</a></li>
        </ul>
      </div>
      <div class="dropdown">
        <img
          src="https://images.pexels.com/photos/6985001/pexels-photo-6985001.jpeg"
          alt="profiel"
          width="32"
          height="32"
          class="rounded-circle dropdown-toggle"
          data-bs-toggle="dropdown"
          style="cursor: pointer"
        />

        <ul class="dropdown-menu dropdown-menu-end text-small shadow">
          <li><a class="dropdown-item" href="#">Profiel</a></li>  <!-- profile page nog aanmaken-->
          <li><hr class="dropdown-divider" /></li>
          <li><a class="dropdown-item" href="index.html">Afmelden</a></li>
        </ul>
      </div>
    </div>
  </header>
  <body class="bg">
    <div class="container py-5 space-y-5">
      <header class="text-center mb-5">
        <h1 class="display-5 fw-bold text-black mb-3">Welkom bij Musicore</h1>
        <p class="lead text-purple-900 mb-4">
          Ontdek, analyseer en geniet van je favoriete muziek
        </p>

        <form
          id="searchForm"
          class="mt-4 mx-auto position-relative"
          style="max-width: 700px"
        >
          <div class="search-wrapper shadow-lg">
            <i data-lucide="search" class="search-icon text-purple-700"></i>
            <input
              type="text"
              id="searchInput"
              class="form-control custom-input"
              placeholder="Zoek naar een artiest of nummer..."
            />
            <button class="btn btn-dark btn-search" type="submit">
              Zoeken
            </button>
          </div>
        </form>
      </header>

      <section class="mb-5">
        <h2 class="h4 fw-bold text-black mb-4">Snelle Acties</h2>
        <div class="row g-4">
          <div class="col-md-6">
            <div class="card action-card border-2 h-100 shadow-sm">
              <div class="card-body d-flex align-items-center p-4">
                <div class="icon-box gradient-blue me-3 text-white">
                  <i data-lucide="rows-3" style="width: 32px; height: 32px"></i>
                </div>
                <div onclick="window.location.href='collection.html'" style="cursor: pointer;">
                  <a href="/collection" class="h5 fw-bold mb-1">Bekijk collecties</h3>
                  <p class="small text-purple-900 ">
                    Blader door je favoriete nummers
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card action-card border-2 h-100 shadow-sm">
              <div class="card-body d-flex align-items-center p-4">
                <div class="icon-box gradient-orange me-3 text-white">
                  <i data-lucide="trophy" style="width: 32px; height: 32px"></i>
                </div>
                <div onclick="window.location.href='guessthesong.html'">
                    <h3 class="h5 fw-bold mb-1">Raad het nummer</h3>
                  <p class="small text-purple-900">Test je muziekkennis</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="mb-5">
        <h2 class="h4 fw-bold text-black mb-4">🎵 Nummer van de week</h2>
        <div class="card song-of-the-week border-2 shadow-sm" onclick="window.location.href='song.html?song=Blinding%20Lights'">
          <div class="card-body p-4 d-flex align-items-center">
            <img
              src="https://images.unsplash.com/photo-1470225620780-dba8ba36b745?w=300"
              alt="Cover"
              class="song-week-img shadow"
            />
            <div class="ms-4 flex-grow-1">
              <h3 class="h3 fw-bold mb-1">Blinding Lights</h3>
              <p class="text-purple-900 fs-5 mb-3">The Weeknd</p>
              <div class="d-flex gap-3 text-sm text-purple-900 ">
                <span>Populariteit: 95%</span>
                <span>Energie: 80%</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="h4 fw-bold text-black">🔥 Populaire Nummers</h2>
        
        </div>
        <div
          id="popularSongsGrid"
          class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3 overflow-hidden"
        ></div>
      </section>
    </div>

    <script src="js/home.js"></script>
    <script src="js/zoek.js"></script>
    <script>
  lucide.createIcons();
</script>
</body>
</html>
