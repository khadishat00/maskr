<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || "Collection" %></title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/style.css" />
  <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body class="bg">
  <header class="py-2 mb-3 border-bottom bg-white">
    <div class="container d-flex align-items-center justify-content-between">
      <div class="logo">
        <a href="/home">
          <img src="/assets/logo.png" alt="logo" width="50" height="50" />
        </a>
      </div>

      <div class="dropdown">
        <button
          class="btn dropdown-toggle"
          type="button"
          data-bs-toggle="dropdown"
          style="background-color: white; border: 2px solid purple; color: black;"
        >
          Kies je mood
        </button>

        <ul class="dropdown-menu">
          <% const moods = ["Blij", "Moe", "Gemotiveerd", "Relaxed"]; %>
          <% moods.forEach(function(mood) { %>
            <li><a class="dropdown-item" href="#"><%= mood %></a></li>
          <% }) %>
        </ul>
      </div>

      <div class="dropdown">
        <img
          src="<%= user?.profileImage || 'https://images.pexels.com/photos/6985001/pexels-photo-6985001.jpeg' %>"
          alt="profiel"
          width="32"
          height="32"
          class="rounded-circle dropdown-toggle"
          data-bs-toggle="dropdown"
          style="cursor: pointer"
        />

        <ul class="dropdown-menu dropdown-menu-end text-small shadow">
          <li><a class="dropdown-item" href="/profile">Profiel</a></li>
          <li><hr class="dropdown-divider" /></li>
          <li><a class="dropdown-item" href="/logout">Afmelden</a></li>
        </ul>
      </div>
    </div>
  </header>

  <div class="container py-5 space-y-5">
    <header class="text-center mb-5">
      <h1 class="display-5 fw-bold text-black mb-3">
        Welkom bij Musicore
      </h1>

      <p class="lead text-purple-900 mb-4">
        Ontdek, analyseer en geniet van je favoriete muziek
      </p>

      <form
        id="searchForm"
        class="mt-4 mx-auto position-relative"
        style="max-width: 700px"
      >
        <div class="search-wrapper shadow-lg">
          <i data-lucide="search" class="search-icon text-purple-700"></i>
          <input
            type="text"
            id="mainSearchInput"
            class="form-control custom-input"
            placeholder="Zoek naar een artiest of nummer..."
          />
          <button class="btn btn-dark btn-search" type="submit">
            Zoeken
          </button>
        </div>
      </form>
    </header>

    <div class="app">
      <div class="library-box">
        <div class="top-row">
          <div class="nav-buttons">
            <button type="button" class="small-button">&#8592;</button>
            <button type="button" class="small-button">&#8594;</button>
          </div>

          <button type="button" id="createButton" class="create-button">
            + Creëren
          </button>
        </div>

        <h1>Uw bibliotheek</h1>

        <div class="filter-row">
          <button type="button" class="filter-button active" data-type="playlist">Playlists</button>
          <button type="button" class="filter-button" data-type="podcast">Podcasts</button>
          <button type="button" class="filter-button" data-type="album">Albums</button>
          <button type="button" class="filter-button" data-type="artist">Artists</button>
        </div>

        <div class="control-row">
          <div class="search-box">
            <span>Search</span>
            <input id="librarySearchInput" type="text" placeholder="Search library">
          </div>

          <div class="sort-box">
            <label for="sortSelect">Recents</label>
            <select id="sortSelect">
              <option value="recent">Recents</option>
              <option value="az">A-Z</option>
              <option value="za">Z-A</option>
            </select>
          </div>
        </div>

        <p id="messageText">
          <%= message || "Loading music..." %>
        </p>

        <div id="playlistList" class="playlist-list">
          <% if (typeof playlists !== "undefined" && playlists.length > 0) { %>
            <% playlists.forEach(function(item) { %>
              <div class="playlist-item" data-type="<%= item.type %>">
                <strong><%= item.title %></strong>
                <p><%= item.creator %></p>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div id="modalBackground" class="modal-background hidden">
    <div class="modal-box">
      <h2>Create Item</h2>

      <form id="createForm">
        <label for="titleInput">Titel</label>
        <input id="titleInput" type="text" required>

        <label for="typeInput">Type</label>
        <select id="typeInput">
          <option value="playlist">Playlist</option>
          <option value="podcast">Podcast</option>
          <option value="album">Album</option>
          <option value="artist">Artiesten</option>
        </select>

        <label for="creatorInput">Creator</label>
        <input id="creatorInput" type="text" placeholder="You">

        <div class="modal-buttons">
          <button type="button" id="cancelButton">Annuleren</button>
          <button type="submit">Opslaan</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/collection.js"></script>
  <script>
    lucide.createIcons();
  </script>
</body>
</html>
