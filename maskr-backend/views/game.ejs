<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Guess The Song</title>
<link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/style.css" />
  <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body class="bg">
  <header class="py-2 mb-3 border-bottom bg-white">
    <div class="container d-flex align-items-center justify-content-between">
      <div class="logo">
        <a href="/home">
          <img src="/assets/logo.png" alt="logo" width="50" height="50" />
        </a>
      </div>

      <div class="dropdown">
        <button
          class="btn dropdown-toggle"
          type="button"
          data-bs-toggle="dropdown"
          style="background-color: white; border: 2px solid purple; color: black;"
        >
          Kies je mood
        </button>

        <ul class="dropdown-menu">
          <% const moods = ["Blij", "Moe", "Gemotiveerd", "Relaxed"]; %>
          <% moods.forEach(function(mood) { %>
            <li><a class="dropdown-item" href="#"><%= mood %></a></li>
          <% }) %>
        </ul>
      </div>

      <div class="dropdown">
        <img
          src="<%= user?.profileImage || 'https://images.pexels.com/photos/6985001/pexels-photo-6985001.jpeg' %>"
          alt="profiel"
          width="32"
          height="32"
          class="rounded-circle dropdown-toggle"
          data-bs-toggle="dropdown"
          style="cursor: pointer"
        />

        <ul class="dropdown-menu dropdown-menu-end text-small shadow">
          <li><a class="dropdown-item" href="/profile">Profiel</a></li>
          <li><hr class="dropdown-divider" /></li>
          <li><a class="dropdown-item" href="/logout">Afmelden</a></li>
        </ul>
      </div>
    </div>
  </header>

  <div class="container py-5 space-y-5">
    <header class="text-center mb-5">
      <h1 class="display-5 fw-bold text-black mb-3">
        Welkom bij Musicore
      </h1>

      <p class="lead text-purple-900 mb-4">
        Ontdek, analyseer en geniet van je favoriete muziek
      </p>

      <form
        id="searchForm"
        class="mt-4 mx-auto position-relative"
        style="max-width: 700px"
      >
        <div class="search-wrapper shadow-lg">
          <i data-lucide="search" class="search-icon text-purple-700"></i>
          <input
            type="text"
            id="mainSearchInput"
            class="form-control custom-input"
            placeholder="Zoek naar een artiest of nummer..."
          />
          <button class="btn btn-dark btn-search" type="submit">
            Zoeken
          </button>
        </div>
      </form>
    </header>
</head>
<body>
  <nav class="navbar">
    <div class="logo">Musicore</div>
    <div class="mood-area">
      <label for="moodSelect">Current Mood</label>
      <select id="moodSelect">
        <option value="chill">Chill</option>
        <option value="happy">Happy</option>
        <option value="party">Party</option>
        <option value="focus">Focus</option>
      </select>
    </div>
    <div class="icons">
      <span>Search</span>
      <span>Fav</span>
      <div class="avatar">U</div>
    </div>
  </nav>
  <main class="container">
    <div class="title-row">
      <h1>Raad het liedje</h1>
      <div class="score-box">
        <span>Score: <span id="score">0</span></span>
        <button id="resetButton">Reset</button>
      </div>
    </div>
    <div id="moodBadge" class="mood-badge">Current Mood: Chill</div>
    <div class="card">
      <h2>Nu aan het afspelen</h2>
      <img id="coverImage" src="" alt="Album cover">
      <button id="playButton">Open het nummer in YouTube Music</button>
      <p id="statusText">Nummer laden...</p>
    </div>
    <div class="card">
      <h2>Wat is dit liedje ?</h2>
      <p>Typ de titel of de naam van de artiest:</p>
      <form id="guessForm">
        <input id="guessInput" type="text" placeholder="Voer je gok in...">
        <button id="submitButton" type="submit" disabled>Dien je gok in</button>
      </form>
      <p id="message"></p>
    </div>
  </main>
  <script src="/js//game.js"></script>
</body>
</html>
