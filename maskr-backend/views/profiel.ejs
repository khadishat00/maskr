<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profiel</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/general.css" />
  </head>

  <body class="bg-light">
    <!-- Header -->
    <header class="py-2 mb-3 border-bottom bg-white">
      <div class="container d-flex align-items-center justify-content-between">
        <img src="/assets/logo.png" alt="logo" width="50" height="50" />
      </div>
    </header>

    <!-- Profiel -->
    <div
      class="container d-flex justify-content-center align-items-center"
      style="min-height: 85vh"
    >
      <div
        class="card shadow p-4 text-center"
        style="max-width: 500px; width: 100%; border-radius: 12px"
      >
        <!-- Profielfoto -->
        <div class="mb-3">
          <img
            src="<%= user.image || '/assets/avatar01.png' %>"
            alt="avatar"
            class="rounded-circle"
            width="100"
            height="100"
          />
        </div>

        <!-- Gebruikersnaam -->
        <h3 class="mb-3"><%= user.username %></h3>

        <!-- Gegevens -->
        <div class="text-start mb-4">
          <p><strong>E-mail:</strong> <%= user.email %></p>
        </div>

        <!-- Knoppen -->
        <div class="d-grid gap-2">
          <a href="/home" class="btn btn-outline-secondary">Home pagina</a>
          <a href="/profiel/edit" class="btn btn-outline-secondary"
            >Profiel wijzigen</a
          >

          <form action="/logout" method="post">
            <button class="btn btn-dark w-100" type="submit">Uitloggen</button>
          </form>
        </div>
      </div>
    </div>
  </body>
</html>
