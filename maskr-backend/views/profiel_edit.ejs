<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profiel bewerken</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/general.css" />

    <style>
      .avatar-option img {
        cursor: pointer;
        border: 3px solid transparent;
      }

      .avatar-radio:checked + img {
        border: 3px solid black;
      }
    </style>
  </head>

  <body class="bg-light">
    <!-- Header -->
    <header class="py-2 mb-3 border-bottom bg-white">
      <div class="container">
        <img src="/assets/logo.png" alt="logo" width="50" height="50" />
      </div>
    </header>

    <!-- Profiel -->
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 85vh">
      <div class="card shadow p-4 text-center" style="max-width: 500px; width: 100%; border-radius: 12px">

        <!-- Huidige avatar -->
        <div class="mb-3">
          <img
            src="<%= user.image || '/assets/avatar01.png' %>"
            alt="avatar"
            class="rounded-circle"
            width="100"
            height="100"
          />
        </div>

        <!-- Form -->
        <form action="/profiel/edit" method="post">

          <!-- Avatar keuze -->
          <div class="mb-3">
            <p><strong>Kies een avatar:</strong></p>

            <div class="d-flex flex-wrap gap-2 justify-content-center">
              <% avatars.forEach(avatar => { %>
                <label class="avatar-option">
                  <input
                    type="radio"
                    name="image"
                    value="<%= avatar %>"
                    class="avatar-radio d-none"
                    <%= (user.image || '/assets/avatar01.png') === avatar ? "checked" : "" %>
                  />

                  <img
                    src="<%= avatar %>"
                    width="60"
                    height="60"
                    class="rounded-circle"
                  />
                </label>
              <% }) %>
            </div>
          </div>

          <!-- Username -->
          <div class="text-start mb-3">
            <label class="form-label"><strong>Gebruikersnaam</strong></label>
            <input
              type="text"
              class="form-control"
              name="username"
              value="<%= user.username %>"
            />
          </div>

          <!-- Email -->
          <div class="text-start mb-3">
            <label class="form-label"><strong>E-mail</strong></label>
            <input
              type="email"
              class="form-control"
              name="email"
              value="<%= user.email %>"
            />
          </div>

          <!-- Wachtwoorden -->
          <div class="text-start mb-3">
            <label class="form-label"><strong>Oud wachtwoord</strong></label>
            <input type="password" class="form-control" name="oudeWachtwoord" />
          </div>

          <div class="text-start mb-3">
            <label class="form-label"><strong>Nieuw wachtwoord</strong></label>
            <input type="password" class="form-control" name="nieuweWachtwoord" />
          </div>

          <!-- Buttons -->
          <div class="d-grid gap-2">
            <button type="submit" class="btn btn-dark">Opslaan</button>
            <a href="/profiel" class="btn btn-outline-secondary">Annuleren</a>
          </div>

        </form>
      </div>
    </div>
  </body>
</html>