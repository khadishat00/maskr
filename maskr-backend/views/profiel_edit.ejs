<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profiel bewerken</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/general.css" />



  </head>

  <body class="bg-light">
    <!-- Header -->
    <header class="py-2 mb-3 border-bottom bg-white">
      <div class="container d-flex align-items-center justify-content-between">
        <div class="logo">
          <img src="/assets/logo.png" alt="logo" width="50" height="50" />
        </div>
      </div>
    </header>

    <!-- Profiel -->
    <div
      class="container d-flex justify-content-center align-items-center"
      style="min-height: 85vh"
    >
      <div
        class="card shadow p-4 text-center"
        style="max-width: 500px; width: 100%; border-radius: 12px"
      >
        <!-- Profielfoto -->
        <div class="mb-3">
          <img
            src="<%= user.image %>"
            alt="avatar"
            class="rounded-circle"
            width="100"
            height="100"
          />
        </div>

      
        <!-- Form -->
        <form action="/profiel/edit" method="post">

          <!-- Avatar keuze -->
          <div class="d-flex gap-2 flex-wrap">
            <% avatars.forEach(avatar => { %>
          <label style="cursor: pointer">
          <input
            type="radio"
            name="image"
            value="<%= avatar %>"
            class="d-none avatar-radio"
            <%= user.image === avatar ? "checked" : "" %>
          />

      <img
        src="<%= avatar %>"
        width="60"
        height="60"
        class="rounded-circle border border-3 <%= user.image === avatar ? 'border-dark' : 'border-light' %>"
      />
    </label>
  <% }) %>
</div>

          <div class="text-start mb-3">
            <label for="username" class="form-label"
              ><strong>Gebruikersnaam</strong></label
            >
            <input
              type="text"
              class="form-control"
              id="username"
              name="username"
              value="<%= user.username %>"
            />
          </div>

          <div class="text-start mb-3">
            <label for="email" class="form-label"
              ><strong>E-mail</strong></label
            >
            <input
              type="email"
              class="form-control"
              id="email"
              name="email"
              value="<%= user.email %>"
            />
          </div>

          <div class="text-start mb-3">
            <label for="oudeWachtwoord" class="form-label"
              ><strong>Oude wachtwoord</strong></label
            >
            <input
              type="password"
              class="form-control"
              id="oudeWachtwoord"
              name="oudeWachtwoord"
            />
          </div>

          <div class="text-start mb-3">
            <label for="nieuweWachtwoord" class="form-label"
              ><strong>nieuwe wachtwoord</strong></label
            >
            <input
              type="password"
              class="form-control"
              id="nieuweWachtwoord"
              name="nieuweWachtwoord"
            />
          </div>

          <div class="d-grid gap-2">
            <button type="submit" class="btn btn-dark">Opslaan</button>
            <a href="/profiel" class="btn btn-outline-secondary">Annuleren</a>
          </div>
        </form>
      </div>
    </div>
  </body>
</html>

    <script>
  document.querySelectorAll(".avatar-radio").forEach(radio => {
    radio.addEventListener("change", () => {
      document.querySelectorAll(".avatar-radio").forEach(r => {
        r.nextElementSibling.classList.remove("border-dark");
        r.nextElementSibling.classList.add("border-light");
      });
      radio.nextElementSibling.classList.remove("border-light");
      radio.nextElementSibling.classList.add("border-dark");
    });
  });
</script>