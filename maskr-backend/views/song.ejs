<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Song Page</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/general.css">
</head>

<body class="song-page">

<header class="py-2 mb-3 border-bottom bg-white">
    <div class="container d-flex align-items-center justify-content-between">

        <div class="logo">
            <a href="/home">
                <img src="/assets/logo.png" alt="logo" width="50" height="50">
            </a>
        </div>

        <div>
            <a href="/home" class="btn btn-outline-dark">
                Terug naar Home
            </a>
        </div>
    </div>
</header>

<main class="container py-5">

    <% if (songs && songs.length > 0) { %>

        <div class="row align-items-center">

            <div class="col-md-4">
                <% if (songs[0].thumbnails && songs[0].thumbnails.length > 0) { %>
                    <img
                        src="<%= songs[0].thumbnails[0].url %>"
                        class="img-fluid rounded"
                        alt="cover"
                    >
                <% } %>
            </div>

            <div class="col-md-8">
                <h1><%= songs[0].name %></h1>
                <p><strong>Artiest:</strong> <%= songs[0].artist.name %></p>
                <p><strong>Album:</strong> <%= songs[0].album?.name || "Onbekend" %></p>
            </div>

        </div>

    <% } else { %>

        <h1>Geen nummer gevonden</h1>

    <% } %>

</main>

</body>
</html>
